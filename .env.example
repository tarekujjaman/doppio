# ── Supabase Postgres (Prisma) ────────────────────────────────────────────────
# Pooled connection (PgBouncer, port 6543) — used by the app at runtime
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Direct connection (port 5432) — used by `prisma migrate` only
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# ── Supabase Auth + Storage ───────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""   # server-only: signed upload URLs, admin delete

# ── STT — OpenAI Whisper (real, verified) · mock for tests ───────────────────
# OpenAI whisper-1 is the working provider: synchronous, ~3-4s on short clips,
# good Bangla + code-switch, returns segment timestamps (needed for click-to-seek
# + Ask citations). gpt-4o-*-transcribe do NOT return segments — keep whisper-1.
STT_PROVIDER="openai"          # openai | mock | twinmind(unverified endpoint)
STT_MODEL="whisper-1"
# TwinMind Ear-3: adapter exists but api.twinmind.com/v1 404s (not GA). Re-enable
# once the real endpoint is confirmed from their developer console.
TWINMIND_API_KEY=""
TWINMIND_API_BASE="https://api.twinmind.com/v1"

# ── OpenAI — LLM + embeddings + STT ──────────────────────────────────────────
OPENAI_API_KEY=""
LLM_PROVIDER="openai"          # openai | mock
LLM_MODEL="gpt-4o-mini"
EMBED_MODEL="text-embedding-3-small"

# ── Budget guards (protect the real-money credits) ───────────────────────────
MAX_TRANSCRIBE_MINUTES_TOTAL="500"    # ~8h at Whisper $0.006/min on a ~$3 budget
MAX_UPLOAD_MB="25"                    # Whisper single-request limit

# ── App ───────────────────────────────────────────────────────────────────────
PAYMENT_PROVIDER="sandbox"
APP_URL="http://localhost:3000"       # prod: https://<project>.vercel.app
