# ── Supabase Postgres (Prisma) ────────────────────────────────────────────────
# Pooled connection (PgBouncer, port 6543) — used by the app at runtime
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Direct connection (port 5432) — used by `prisma migrate` only
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# ── Supabase Auth + Storage ───────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""   # server-only: signed upload URLs, admin delete

# ── STT — TwinMind primary, OpenAI fallback, mock for dev ────────────────────
STT_PROVIDER="mock"            # mock | twinmind | openai
TWINMIND_API_KEY=""
TWINMIND_API_BASE="https://api.twinmind.com/v1"
STT_MODEL="gpt-4o-mini-transcribe"   # used only by the OpenAI fallback adapter

# ── OpenAI — LLM + embeddings (+ STT fallback) ───────────────────────────────
OPENAI_API_KEY=""
LLM_PROVIDER="mock"            # mock | openai
LLM_MODEL="gpt-4o-mini"
EMBED_MODEL="text-embedding-3-small"

# ── Budget guards (protect the real-money credits) ───────────────────────────
MAX_TRANSCRIBE_MINUTES_TOTAL="2400"   # ~40h, backed by TwinMind $10
MAX_UPLOAD_MB="100"                   # TwinMind limit (use 25 with the OpenAI fallback)

# ── App ───────────────────────────────────────────────────────────────────────
PAYMENT_PROVIDER="sandbox"
APP_URL="http://localhost:3000"       # prod: https://<project>.vercel.app
