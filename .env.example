# ── Supabase Postgres (Prisma) ────────────────────────────────────────────────
# Pooled connection (PgBouncer, port 6543) — used by the app at runtime
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Direct connection (port 5432) — used by `prisma migrate` only
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# ── Supabase Auth + Storage ───────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""   # server-only: signed upload URLs, admin delete

# ── STT — TwinMind Ear-3 primary, Whisper fallback, mock for tests ───────────
# TwinMind Ear-3 (api.twinmind.dev) is the most accurate Bangla/code-switch
# provider with diarization. It accepts mp3/m4a/wav/flac/ogg/aac but NOT webm,
# so Chrome recordings automatically fall back to OpenAI whisper-1 (which also
# runs a Bengali-script second pass). gpt-4o-*-transcribe omit segment
# timestamps that click-to-seek + Ask citations need — keep whisper-1.
STT_PROVIDER="twinmind"        # twinmind | openai | mock
TWINMIND_API_KEY="sk_live_..."
TWINMIND_API_BASE="https://api.twinmind.dev/v1"
TWINMIND_MODEL="ear-3-pro"     # ear-3-pro ($0.20/hr, most accurate) | ear-3-fast ($0.12/hr)
STT_MODEL="whisper-1"          # used by the OpenAI fallback adapter

# ── OpenAI — LLM + embeddings + STT fallback ─────────────────────────────────
OPENAI_API_KEY=""
LLM_PROVIDER="openai"          # openai | mock
LLM_MODEL="gpt-4o-mini"
EMBED_MODEL="text-embedding-3-small"

# ── Budget guards (protect the real-money credits) ───────────────────────────
MAX_TRANSCRIBE_MINUTES_TOTAL="2000"   # ~33h; TwinMind $0.20/hr against ~$10 balance
MAX_UPLOAD_MB="25"                    # Whisper-fallback single-request limit

# ── App ───────────────────────────────────────────────────────────────────────
PAYMENT_PROVIDER="sandbox"
APP_URL="http://localhost:3000"       # prod: https://<project>.vercel.app
