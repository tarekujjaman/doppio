{
  "manifest_version": 3,
  "name": "Doppio — Capture",
  "version": "0.1.0",
  "description": "Capture browser-tab meetings into Doppio: live tab audio → transcript, summary, action items.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Open Doppio",
    "default_icon": { "16": "icons/icon16.png", "32": "icons/icon32.png", "48": "icons/icon48.png" }
  },
  "background": { "service_worker": "service-worker.js", "type": "module" },
  "side_panel": { "default_path": "index.html" },
  "permissions": ["tabCapture", "offscreen", "storage", "sidePanel", "tabs", "activeTab", "notifications"],
  "host_permissions": ["https://doppio-gamma.vercel.app/*", "https://*.supabase.co/*"],
  "commands": {
    "stop-recording": {
      "suggested_key": { "default": "Alt+Shift+R" },
      "description": "Stop the current Doppio recording"
    }
  },
  "minimum_chrome_version": "116"
}
