<?xml version="1.0" encoding="utf-8"?>
<!-- Android 12+ backup/transfer rules. Exclude on-device audio recordings from both
     cloud backup and device-to-device transfer so recordings stay device-only. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="file" path="recordings/" />
        <exclude domain="external" path="recordings/" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="recordings/" />
        <exclude domain="external" path="recordings/" />
    </device-transfer>
</data-extraction-rules>
