<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Compose draws the UI; this Activity theme only sets the window chrome.
         Uses a platform theme so no Material-Components XML dependency is needed. -->
    <style name="Theme.Doppio" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/white</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
</resources>
