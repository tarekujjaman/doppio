<!-- Doppio mark (reversed): "you" (paper) + "the echo" (coral) + "the spark" (overlap).
     Drawn in 0..100 mark space, scaled/centered into the 108 adaptive-icon safe zone. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <group
        android:scaleX="0.74"
        android:scaleY="0.74"
        android:translateX="17"
        android:translateY="17">
        <!-- you -->
        <path
            android:fillColor="#F3EEE9"
            android:pathData="M16,46 a26,26 0 1,0 52,0 a26,26 0 1,0 -52,0 Z" />
        <!-- the echo -->
        <path
            android:fillColor="#F0664A"
            android:pathData="M40,58 a22,22 0 1,0 44,0 a22,22 0 1,0 -44,0 Z" />
        <!-- the spark: echo clipped to the "you" disc -->
        <group>
            <clip-path android:pathData="M16,46 a26,26 0 1,0 52,0 a26,26 0 1,0 -52,0 Z" />
            <path
                android:fillColor="#F4A47E"
                android:pathData="M40,58 a22,22 0 1,0 44,0 a22,22 0 1,0 -44,0 Z" />
        </group>
    </group>
