{
  "name": "doppio",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo dev --filter=@doppio/web",
    "build": "turbo build",
    "test": "turbo test",
    "e2e": "pnpm --filter @doppio/web e2e",
    "lint": "turbo lint",
    "db:generate": "pnpm --filter @doppio/db generate",
    "db:migrate": "pnpm --filter @doppio/db migrate:deploy",
    "db:seed": "pnpm --filter @doppio/db seed",
    "eval:bangla": "pnpm --filter @doppio/ai eval:bangla"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.3.3"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.0.14",
      "@types/react-dom": "19.0.6"
    }
  }
}
